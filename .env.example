# Copy this file to .env.local and fill in your values
ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
NEXT_PUBLIC_FOUNDER_ADDRESS=0xYourFounderWalletAddress
NEXT_PUBLIC_FEE_CONTRACT_ETH=
NEXT_PUBLIC_FEE_CONTRACT_BASE=
ALCHEMY_API_KEY=your_eth_mainnet_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Google Search Console — HTML tag verification method.
# search.google.com/search-console -> Add property -> usesalvage.xyz
# -> "HTML tag" method -> copy just the `content="..."` value below.
GOOGLE_SITE_VERIFICATION=

# WalletConnect — cloud.reown.com -> your "Salvage" project -> Project ID
# (shown right on the project overview page, a short alphanumeric string).
# Lets mobile browser users with no extension connect via QR/deep-link.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
