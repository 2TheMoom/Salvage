{
  "manifest_version": 3,
  "name": "Salvage — Stranded Token Warning",
  "version": "1.0.0",
  "description": "Warns you before sending ERC-20 tokens to a contract address instead of a wallet — the #1 way tokens get permanently stranded.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Open Salvage to check an address"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.usesalvage.xyz/*"
  ],
  "permissions": [
    "storage"
  ]
}
